[
  {
    "label": "Television File Finder",
    "command": "zed \"$(tv files)\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
  },
  {
    "label": "Full-text Search (tv text)",
    "command": "zed \"$(tv text)\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
  },
  {
    "label": "Run HTTP Request",
    "command": "httpyac",
    "args": ["send", "--line", "$ZED_ROW", "$ZED_FILE"],
    "tags": ["http-request", "$http", "$http-test"],
    "reveal": "always",
    "hide": "never",
    "allow_concurrent_runs": true,
  },
  {
    "label": "Run Maven Package",
    "command": "mvn clean package -DskipTests=true -T 4",
    "args": [],
    "reveal": "always",
    "hide": "never",
    "allow_concurrent_runs": false,
  },
]
