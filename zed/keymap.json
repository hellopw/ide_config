// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "alt-f":"workspace::ToggleZoom",
      // 文件查找
      "shift shift": "file_finder::Toggle",
      "ctrl p": [
        // Or `ctrl-p`
        "task::Spawn",
        { "task_name": "Television File Finder", "reveal_target": "center" },
      ],
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "ctrl-v": "editor::Paste",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-a": "editor::SelectAll", // vim default: increment
      "ctrl-b": "editor::GoToNextReference", // vim default: return to normal mode
      "ctrl-c": "editor::Copy", // vim default: return to normal mode
      "ctrl-d": "editor::DuplicateSelection", // vim default: return to normal mode
      "ctrl-f": "buffer_search::Deploy", // vim default: page down
      "ctrl-o": "workspace::Open", // vim default: go back
      "ctrl-s": "workspace::Save", // vim default: show signature
      "ctrl-x": "editor::Cut", // vim default: decrement
      "ctrl-y": "editor::Undo", // vim default: line up
      "shift-v": "editor::Paste", // vim default: increment
      "ctrl--": "editor::ToggleFold",
      "ctrl-shift--": "editor::FoldAll",
      "ctrl-=": "editor::ToggleFold",
      "ctrl-shift-=": "editor::UnfoldAll" // 这个本来就是这个，不需要单独加
    },
  },
  // {
